   "source": [
    "### 1. Create a NumPy array from a Python list. Print the following: shape,dtype, ndim."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 1,
   "id": "6e97e056",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Shape of the array is  (6,)\n",
      "Data type of the array is  int64\n",
      "The dimension of the array is  1\n"
     ]
    }
   ],
   "source": [
    "import numpy as np\n",
    "l = [1,2,3,4,5,6]\n",
    "arr = np.array(l)\n",
    "print(\"Shape of the array is \", arr.shape) \n",
    "print(\"Data type of the array is \", arr.dtype)\n",
    "print(\"The dimension of the array is \", arr.ndim)"
   ]
