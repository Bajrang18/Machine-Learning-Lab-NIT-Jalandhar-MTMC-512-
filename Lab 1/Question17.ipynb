   "source": [
    "### 17. Create two NumPy arrays where the Pearson correlation is near 0, but the Spearman (rank) correlation is 1.0. Explain why this happens."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 1,
   "id": "6fecdf27",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "PearsonRResult(statistic=np.float64(0.9084337349397589), pvalue=np.float64(0.0002750317364150482))\n",
      "SignificanceResult(statistic=np.float64(0.9999999999999999), pvalue=np.float64(6.646897422032013e-64))\n"
     ]
    }
   ],
   "source": [
    "import numpy as np\n",
    "x = np.arange(10)\n",
    "y = x**3\n",
    "\n",
    "from scipy.stats import pearsonr, spearmanr\n",
    "print(pearsonr(x,y))\n",
    "print(spearmanr(x,y))\n"
   ]
  },
