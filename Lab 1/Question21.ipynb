   "source": [
    "### 21. What is the Difference between copy() and assignment (=) NumPy. Demonstrate with code."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 2,
   "id": "40c8c4ed",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "[99  2  3]\n",
      "[1 2 3]\n"
     ]
    }
   ],
   "source": [
    "import numpy as np\n",
    "a = np.array([1,2,3])\n",
    "b = a\n",
    "c = a.copy()\n",
    "\n",
    "a[0] = 99\n",
    "print(b)  # changed\n",
    "print(c)  # unchanged"
   ]
