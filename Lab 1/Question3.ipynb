   "source": [
    "### 3. What is the difference between np.array() and np.asarray()?"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "bb8d4eca",
   "metadata": {},
   "source": [
    "np.array() always creates a new copy of array, \n",
    "np.asarray() avoids copy if input is already an nd array"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 2,
   "id": "10541f6e",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "True\n"
     ]
    }
   ],
   "source": [
    "import numpy as np\n",
    "a = np.array([1,2,3])\n",
    "b = np.asarray(a)\n",
    "print(a is b)\n"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "f2d6dd8b",
   "metadata": {},
   "source": []
  }
